<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <PackageId>DisposableEmailDomain</PackageId>
    <Version>1.0.13</Version>
    <Authors>Mehrdad TAT</Authors>
    <Description>Aggregated, deduped, normalized list of disposable / temporary email domains, with an IsDisposable() helper. Auto-refreshed daily.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>disposable;temporary;email;domains;blocklist;validation</PackageTags>
    <RepositoryUrl>https://github.com/mehrtat/disposable-email-domain</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/mehrtat/disposable-email-domain</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- Fixed logical name so the reader does not depend on assembly/namespace. -->
    <EmbeddedResource Include="domains.txt">
      <LogicalName>domains.txt</LogicalName>
    </EmbeddedResource>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
